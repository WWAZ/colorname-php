{
    "name": "wwaz/colornames-php",
    "description": "Load and find color names by RGB value",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/wwaz/colornames-php",
    "keywords": [
        "color",
        "color-name",
        "hex",
        "rgb"
    ],
    "support": {
        "issues": "https://github.com/wwaz/colornames-php/issues",
        "source": "https://github.com/wwaz/colornames-php"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "wwaz\\Colornames\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "wwaz\\Colornames\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
